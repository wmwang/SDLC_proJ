    {
      "type": "text",
      "id": "r1c2_text",
      "x": 320,
      "y": 210,
      "width": 360,
      "height": 120,
      "text": "• 1.1 Motivation: Clarify motivation & business value\n• 1.2 Non-goals: Boundary non-goals, no over-eng\n• 1.3 Trade-offs: Document technical path selections\n• 1.4 BDD Specs: Define SHALL/MUST in WHEN/THEN",
      "originalText": "• 1.1 Motivation: Clarify motivation & business value\n• 1.2 Non-goals: Boundary non-goals, no over-eng\n• 1.3 Trade-offs: Document technical path selections\n• 1.4 BDD Specs: Define SHALL/MUST in WHEN/THEN",
      "fontSize": 11,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#374151",
      "backgroundColor": "transparent",
