    {
      "type": "text",
      "id": "evidence_cli_text",
      "x": 565,
      "y": 385,
      "width": 370,
      "height": 80,
      "text": "# 步驟 4：驗證 Schema 設定\nopenspec schema validate qa-heavy-sdlc\n\n# 步驟 5：啟用新 Schema 建立 Change\nopenspec new my-feature --schema qa-heavy-sdlc",
      "originalText": "# 步驟 4：驗證 Schema 設定\nopenspec schema validate qa-heavy-sdlc\n\n# 步驟 5：啟用新 Schema 建立 Change\nopenspec new my-feature --schema qa-heavy-sdlc",
